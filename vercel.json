{
  "version": 2,
  "builds": [
    { "src": "api-chat.js", "use": "@vercel/node" },
    { "src": "api-zodiac.js", "use": "@vercel/node" },
    { "src": "DEPLOY.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api-chat.js" },
    { "src": "/api/zodiac", "dest": "/api-zodiac.js" },
    { "src": "/", "dest": "/DEPLOY.html" }
  ]
}
